[
  {
    "fields": [
      {
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ]
          }
        ],
        "description": "e.g. \"Logitech — Quickstrike Mouse Launch\"",
        "name": "title",
        "type": "string"
      },
      {
        "options": {
          "source": "title",
          "maxLength": 80
        },
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "custom"
              },
              {
                "flag": "presence",
                "constraint": "required"
              }
            ]
          }
        ],
        "name": "slug",
        "type": "slug",
        "title": "Slug (URL)"
      },
      {
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              },
              {
                "flag": "min",
                "constraint": 2000
              },
              {
                "flag": "max",
                "constraint": 2030
              }
            ]
          }
        ],
        "name": "year",
        "type": "number"
      },
      {
        "description": "Visible on the project page. Leave blank to omit.",
        "name": "client",
        "type": "string",
        "title": "Client (leave blank for NDA)"
      },
      {
        "description": "e.g. \"Art Direction, Motion Design\"",
        "name": "role",
        "type": "string"
      },
      {
        "options": {
          "list": [
            {
              "title": "Art Direction",
              "value": "art-direction"
            },
            {
              "title": "Branding",
              "value": "branding"
            },
            {
              "title": "Motion",
              "value": "motion"
            },
            {
              "title": "Social Media",
              "value": "social-media"
            },
            {
              "title": "AI",
              "value": "ai"
            },
            {
              "title": "3D",
              "value": "3d"
            },
            {
              "title": "Photography",
              "value": "photography"
            },
            {
              "title": "Web & App",
              "value": "web-app"
            }
          ]
        },
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "valid",
                "constraint": [
                  "art-direction",
                  "branding",
                  "motion",
                  "social-media",
                  "ai",
                  "3d",
                  "photography",
                  "web-app"
                ]
              },
              {
                "flag": "min",
                "constraint": 1
              }
            ]
          }
        ],
        "of": [
          {
            "type": "string"
          }
        ],
        "name": "tags",
        "type": "array"
      },
      {
        "rows": 6,
        "description": "Case study text. Write what you did, why it matters.",
        "name": "description",
        "type": "text"
      },
      {
        "options": {
          "hotspot": true
        },
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ]
          }
        ],
        "description": "Shown on the homepage card. 16:9 recommended.",
        "name": "coverImage",
        "type": "image"
      },
      {
        "description": "Images and loop videos for the project page. Drag to reorder.",
        "of": [
          {
            "fields": [
              {
                "options": {
                  "hotspot": true
                },
                "validation": [
                  {
                    "level": "error",
                    "rules": [
                      {
                        "flag": "presence",
                        "constraint": "required"
                      }
                    ]
                  }
                ],
                "name": "image",
                "type": "image"
              },
              {
                "options": {
                  "list": [
                    {
                      "title": "16:9 (landscape)",
                      "value": "16:9"
                    },
                    {
                      "title": "9:16 (portrait / phone)",
                      "value": "9:16"
                    },
                    {
                      "title": "1:1 (square)",
                      "value": "1:1"
                    },
                    {
                      "title": "4:3 (classic)",
                      "value": "4:3"
                    }
                  ]
                },
                "initialValue": "16:9",
                "name": "aspectRatio",
                "type": "string"
              },
              {
                "name": "caption",
                "type": "string",
                "title": "Caption (optional)"
              }
            ],
            "type": "object",
            "name": "galleryImage",
            "title": "Image"
          }
        ],
        "name": "gallery",
        "type": "array"
      },
      {
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "uri",
                "constraint": {
                  "options": {
                    "scheme": [
                      "/^http$/",
                      "/^https$/"
                    ],
                    "allowRelative": false,
                    "relativeOnly": false,
                    "allowCredentials": false
                  }
                }
              }
            ]
          }
        ],
        "description": "e.g. https://vimeo.com/123456789 — embedded as the hero of the project page.",
        "name": "vimeoUrl",
        "type": "url",
        "title": "Vimeo URL"
      },
      {
        "options": {
          "accept": "video/mp4,video/webm"
        },
        "description": "Silent autoplay loop shown in the gallery. Better than GIF.",
        "name": "loopVideo",
        "type": "file",
        "title": "Loop Video (MP4)"
      },
      {
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "uri",
                "constraint": {
                  "options": {
                    "scheme": [
                      "/^http$/",
                      "/^https$/"
                    ],
                    "allowRelative": false,
                    "relativeOnly": false,
                    "allowCredentials": false
                  }
                }
              }
            ]
          }
        ],
        "description": "Only for your own projects. Shown as the last element of the case study.",
        "name": "liveUrl",
        "type": "url",
        "title": "Live URL (own sites only)"
      },
      {
        "description": "e.g. \"With Marta Fernández (video production)\"",
        "name": "collaborators",
        "type": "string"
      },
      {
        "description": "If set, the project page is password-protected. Name and thumbnail are always visible.",
        "name": "password",
        "type": "string",
        "title": "Password (NDA projects)"
      },
      {
        "initialValue": false,
        "description": "Pinned to top on homepage regardless of display order.",
        "name": "featured",
        "type": "boolean"
      },
      {
        "initialValue": 99,
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ]
          }
        ],
        "description": "Lower = higher on the page. Set manually.",
        "name": "displayOrder",
        "type": "number"
      },
      {
        "initialValue": true,
        "description": "Hide from site without deleting.",
        "name": "visible",
        "type": "boolean"
      }
    ],
    "name": "project",
    "type": "document"
  }
]