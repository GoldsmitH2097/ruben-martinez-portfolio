---
interface Props {
  title?: string;
  lang?: string;
}
const { title = 'Rubén Martínez', lang = 'en' } = Astro.props;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Rubén Martínez — Art Director, Creative Lead & Visual Designer. 15+ years in advertising, branding and digital. Currently leading creative at Shuttlerock Europe. Based in Barcelona." />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://ruben-martinez.com" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" hreflang="en" href="https://ruben-martinez.com/" />
    <link rel="alternate" hreflang="es" href="https://ruben-martinez.com/es/" />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Rubén Martínez",
      "jobTitle": "Art Director & Creative Lead",
      "url": "https://ruben-martinez.com",
      "sameAs": [
        "https://www.behance.net/RubenMartinez",
        "https://www.linkedin.com/in/rubenmartinezlopez"
      ],
      "worksFor": {
        "@type": "Organization",
        "name": "Shuttlerock"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Barcelona",
        "addressCountry": "ES"
      }
    }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:ital,wght@0,300;0,400;1,300&family=DM+Mono:wght@300&display=swap" rel="stylesheet" />
    <title>{title}</title>

    <!-- Google Analytics — replace G-XXXXXXXXXX with your Measurement ID -->
    <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script> -->
  </head>
  <body>
    <slot />
    
  <script>
  // ── Custom cursor: dot + trailing ring ────────────────────
  if (window.matchMedia('(pointer: fine)').matches) {
    document.body.style.cursor = 'none';

    const dot  = Object.assign(document.createElement('div'), { className: 'c-dot' });
    const ring = Object.assign(document.createElement('div'), { className: 'c-ring' });
    document.body.append(dot, ring);

    let mx = -100, my = -100, rx = -100, ry = -100;
    let hovering = false;

    document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });

    document.querySelectorAll('a, button, .project-card, .filter-btn').forEach(el => {
      el.style.cursor = 'none';
      el.addEventListener('mouseenter', () => hovering = true);
      el.addEventListener('mouseleave', () => hovering = false);
    });

    let raf;
    function loop() {
      // dot snaps instantly
      dot.style.transform = `translate(${mx}px,${my}px)`;

      // ring lags behind
      rx += (mx - rx) * 0.12;
      ry += (my - ry) * 0.12;
      ring.style.transform = `translate(${rx}px,${ry}px) scale(${hovering ? 1.8 : 1})`;
      ring.style.opacity = hovering ? '0.5' : '0.25';

      raf = requestAnimationFrame(loop);
    }
    loop();
  }
</script>
</body>
</html>
