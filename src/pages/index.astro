---
import Base from '../layouts/Base.astro';
import { fetchProjectsWithTags as fetchProjects } from '../scripts/fetchProjects.mjs';
import { useTranslations } from '../i18n/translations';
import '../styles/global.css';

const t = useTranslations('en');
const data = await fetchProjects();
const projects = data.projects;
---

<Base title="Rubén Martínez — Art Director" lang="en">
  <!-- Nav -->
  <nav class="nav">
    <span class="nav-logo">RM</span>
    <div class="nav-links">
      <a href="#work">{t('nav.work')}</a>
      <a href="mailto:rubenmartinezlopez&#64;gmail.com">{t('nav.contact')}</a>
      <a href="/es/" class="nav-lang">ES</a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <!-- Left column: name + tagline -->
    <div class="hero-left">
      <div class="hero-eyebrow">
        <span class="dot"></span>
        <span>Available for projects</span>
      </div>
      <h1 class="hero-name">
        Jack of all<br />trades,<br /><em>master of AI.</em>
      </h1>
      <div class="hero-meta">
        <span class="hero-scroll">Scroll</span>
      </div>
    </div>
    <!-- Right column: role + bio -->
    <div class="hero-right">
      <p class="hero-tagline">Art Director · Creative Lead · Visual Designer</p>
      <p class="hero-bio">Art Director. Creative Lead. Occasional photography nerd. Accidental craft beer founder. I've made ads for McDonald's in San Francisco, branding for craft beers in Vietnam, and reels for BMW in Barcelona — sometimes in the same week. Currently leading creative at Shuttlerock Europe. I do a bit of everything visual, and I do it better with AI.</p>
    </div>
  </section>

  <!-- Work -->
  <section class="projects" id="work">
    <div class="section-header">
      <h2 class="section-title">{t('work.title')}</h2>
      
    </div>

    {projects.length > 0 ? (
      <div class="projects-grid">
        {projects.map((project, i) => (
          <article class="project-card" style={`--i:${i}`}>
            <a href={project.link} target="_blank" rel="noopener" class="card-link">
              <div class="card-media">
                {project.thumbnail ? (
                  <img src={project.thumbnail} alt={project.title} loading="lazy" decoding="async" />
                ) : (
                  <div class="card-placeholder">
                    <span>{String(i + 1).padStart(2, '0')}</span>
                  </div>
                )}
                <div class="card-overlay">
                  <span class="view-label">{t('work.view')} ↗</span>
                </div>
              </div>
              <div class="card-info">
                <h3 class="card-title">{project.title}</h3>
                {project.tags && project.tags.length > 0 && (
                  <div class="card-tags">
                    {project.tags.map((tag) => (
                      <span class={`tag tag--${tag}`}>{tag.replace(/-/g, ' ')}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <div style="padding: 5rem 0; text-align: center;">
        <p style="font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-muted); letter-spacing: 0.1em; margin-bottom: 1.5rem;">
          {t('work.empty')}
        </p>
        <a href="https://www.behance.net/RubenMartinez" target="_blank" rel="noopener"
           style="font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent);">
          {t('work.behance')} →
        </a>
      </div>
    )}
  </section>

  <!-- Footer / Contact -->
  <footer class="footer">
    <div class="footer-left">
      <p>{t('contact.title')}</p>
      <a
        class="footer-email"
        href="mailto:rubenmartinezlopez&#64;gmail.com"
        aria-label="Email Rubén Martínez"
      >
        rubenmartinezlopez<wbr />&#64;gmail.com
      </a>
    </div>
    <div class="footer-links">
      <a href="https://www.behance.net/RubenMartinez" target="_blank" rel="noopener">Behance</a>
      <a href="/cv.pdf" target="_blank" rel="noopener">{t('contact.cv')}</a>
      <p class="footer-copy">© {new Date().getFullYear()} Rubén Martínez · {t('footer.built')}</p>
    </div>
  </footer>
</Base>
